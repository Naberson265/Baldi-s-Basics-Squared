      m_Calls: []
  m_text: 'Baldi''s Basics Squared is a fangame that expands on BBCR. It''s built
    from the ground up in Unity, based on Classic decompiles.


    This is version
    0.0.7f. This version is even more fixes, modifier changes, and some structures
    like conveyors and vents! This also fully fixes the math machine, adds bonus
    questions, and the balloon buster activity. There may be issues so report any
    to the gamebanana issues tab or itch io comments. Next update is either a patch
    or 0.0.8.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 4daca62eaa9d0d549a7588913a6a1249, type: 2}
